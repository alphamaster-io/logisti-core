# ─── Environment ────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ─── App URLs ───────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000

# ─── API ────────────────────────────────────────────────────────
API_PORT=4000
API_GLOBAL_PREFIX=api/v1

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://logisti:logisti@localhost:5432/logisti_core?schema=public

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-strong-secret-min-32-chars-aaaaaaaa
JWT_REFRESH_SECRET=replace-with-different-strong-secret-bbbbbbbb
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Object Storage (MinIO/S3) ──────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=logisti-core
S3_ACCESS_KEY=minio-admin
S3_SECRET_KEY=minio-admin-password
S3_FORCE_PATH_STYLE=true

# ─── Auth Hardening ─────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=12

# ─── Seed (dev only) ────────────────────────────────────────────
SEED_MASTER_EMAIL=alphabyte.master@logisti-core.local
SEED_MASTER_PASSWORD=AlphabyteMaster!2026
SEED_SUPERADMIN_EMAIL=admin@logisti-core.local
SEED_SUPERADMIN_PASSWORD=ChangeMe!Now-2026

# ─── Web (Next.js) ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
WEB_PORT=3000
