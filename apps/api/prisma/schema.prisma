// LogistiCore — Phase 1 schema.
//
// Design principles (carried over from the legacy ExSpeed audit):
//  - tenant_id on every business table (multi-tenant from day 1)
//  - soft delete via deletedAt; no row is ever truly removed in normal flow
//  - audit_logs captures every mutation (interceptor-driven)
//  - state changes are recorded as events; no enum-only state machines
//  - no year-suffixed tables; created_at is the rolling axis
//  - amounts are bigint minor units + currency code, never floats

generator client {
  provider      = "prisma-client-js"
  // debian-slim runtime in Cloud Run + native for local dev
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenant ────────────────────────────────────────────────────
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  currency  String   @default("HKD")
  timezone  String   @default("Asia/Hong_Kong")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users         User[]
  branches      Branch[]
  warehouses    Warehouse[]
  zones         WarehouseZone[]
  racks         Rack[]
  bins          Bin[]
  auditLogs     AuditLog[]
  activityLogs  ActivityLog[]
  serviceOrders     ServiceOrder[]
  boxes             Box[]
  paymentLines      PaymentLine[]
  agents            Agent[]
  boxNumberBatches  BoxNumberBatch[]

  @@map("tenants")
}

// ─── Identity & access ────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String
  emailNormalized String
  name          String
  passwordHash  String
  isActive      Boolean   @default(true)
  // Master users can impersonate any role and switch branch context.
  // Use sparingly. All master actions are still audited.
  isMaster      Boolean   @default(false)
  // When set, the user is acting as this role only (subset of their granted roles).
  // For masters this can be any role key. Cleared on logout.
  activeRoleKey String?
  // Optional branch context override; masters can pick any branch.
  activeBranchId String?
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  failedLoginAttempts Int @default(0)
  lockedUntil   DateTime?
  lastLoginAt   DateTime?
  branchId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  branch        Branch?             @relation(fields: [branchId], references: [id])
  roles         UserRole[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs     AuditLog[]
  activityLogs  ActivityLog[]

  @@unique([tenantId, emailNormalized])
  @@index([tenantId])
  @@index([branchId])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedById String?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Warehouse structure ──────────────────────────────────────
model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  region    String?
  timezone  String   @default("Asia/Hong_Kong")
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  users         User[]
  warehouses    Warehouse[]
  serviceOrders ServiceOrder[]
  agents        Agent[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String
  code      String
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  branch Branch          @relation(fields: [branchId], references: [id])
  zones  WarehouseZone[]

  @@unique([tenantId, code])
  @@index([branchId])
  @@map("warehouses")
}

model WarehouseZone {
  id          String   @id @default(cuid())
  tenantId    String
  warehouseId String
  code        String
  name        String
  zoneType    String   @default("storage")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  racks     Rack[]

  @@unique([warehouseId, code])
  @@map("warehouse_zones")
}

model Rack {
  id        String   @id @default(cuid())
  tenantId  String
  zoneId    String
  code      String
  rows      Int      @default(1)
  columns   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  zone   WarehouseZone @relation(fields: [zoneId], references: [id])
  bins   Bin[]

  @@unique([zoneId, code])
  @@map("racks")
}

model Bin {
  id        String   @id @default(cuid())
  tenantId  String
  rackId    String
  code      String
  capacity  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  rack   Rack   @relation(fields: [rackId], references: [id])

  @@unique([rackId, code])
  @@map("bins")
}

// ─── Audit ────────────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  userId      String?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  requestId   String?
  createdAt   DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@index([userId])
  @@map("audit_logs")
}

model ActivityLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([userId])
  @@map("activity_logs")
}

// ─── Box catalog ──────────────────────────────────────────────
// First slice of Phase 2 per openspec/changes/align-with-exspeed-workflows.
// Box Types are the platform's primary SKU. Dimensions, loyalty point value,
// liability cap, and per-region prices are pinned per the HK price list.

enum BoxTypeCode {
  KING
  SUPER
  JUMBO
  REGULAR
  MEDIUM
  SMALL
  EX_BUDGET
  OVERSIZE
  ODD_SIZE
}

enum RegionZone {
  MNL_RIZAL
  LUZON_A
  LUZON_B
  BICOL_VISAYAS
  MINDANAO_ISLANDS
}

enum ServiceMode {
  DELIVER_BOX
  PICK_UP_BOX
  INSTANT_PACK
  STORAGE
  AGENT_INTAKE
  MACAU_INTAKE
}

model BoxType {
  id                  String      @id @default(cuid())
  code                BoxTypeCode @unique
  displayName         String
  lengthIn            Int? // null for OVERSIZE / ODD_SIZE
  widthIn             Int?
  heightIn            Int?
  loyaltyPointsPerBox Int         @default(0)
  liabilityCapAmount  BigInt? // minor units; null for OVERSIZE / ODD_SIZE
  liabilityCapCurrency String?
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?

  prices BoxPrice[]

  @@map("box_types")
}

model BoxPrice {
  id            String       @id @default(cuid())
  boxTypeId     String
  regionZone    RegionZone
  currencyCode  String // "PHP", "HKD"
  amountMinor   BigInt
  serviceMode   ServiceMode? // null = regular; or INSTANT_PACK / TAKE_OUT discount variant
  isDiscount    Boolean      @default(false) // true when this is an instant-pack or take-out discount line
  effectiveFrom DateTime     @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  boxType BoxType @relation(fields: [boxTypeId], references: [id], onDelete: Cascade)

  @@unique([boxTypeId, regionZone, currencyCode, serviceMode, effectiveFrom])
  @@index([boxTypeId, regionZone])
  @@map("box_prices")
}

enum AccessoryCode {
  PADLOCK
  TAPE_CLEAR
  STORAGE_BAG_S
  STORAGE_BAG_M
  STORAGE_BAG_L
  STORAGE_BAG_LOGO
}

model Accessory {
  id           String        @id @default(cuid())
  code         AccessoryCode @unique
  displayName  String
  amountMinor  BigInt
  currencyCode String // HKD per the HK pricelist
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@map("accessories")
}

enum TvSizeBracket {
  IN_25_29
  IN_30_34
  IN_35_42
  IN_43_50
  IN_51_64
}

model TvPrice {
  id            String        @id @default(cuid())
  sizeBracket   TvSizeBracket
  regionZone    RegionZone
  currencyCode  String // PHP per the price list
  amountMinor   BigInt
  effectiveFrom DateTime      @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([sizeBracket, regionZone, currencyCode, effectiveFrom])
  @@index([sizeBracket, regionZone])
  @@map("tv_prices")
}

// Province → RegionZone lookup, seeded from HKG_PRICE_LIST_20012024 footnotes.
model RegionZoneMap {
  id        String     @id @default(cuid())
  province  String     @unique
  zone      RegionZone
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([zone])
  @@map("region_zone_map")
}

// ─── Service Orders ────────────────────────────────────────────
// The customer-facing engagement. Per
// openspec/changes/align-with-exspeed-workflows/specs/service-orders/spec.md.
// This slice models the entity + draft lifecycle + cancel. Boxes,
// PaymentLines, Declarations are wired in follow-up slices.

enum ServiceOrderStatus {
  DRAFT
  DEPOSIT_COLLECTED
  STORED
  PACKING_SCHEDULED
  PACKED
  AWAITING_FULL_PAYMENT
  PAID_IN_FULL
  OVERDUE
  IN_WAREHOUSE
  PALLETIZED
  SHIPPED
  DELIVERED
  FAILED_DELIVERY
  PENDING_ABANDONMENT
  ABANDONED
  CANCELLED
}

enum ServiceOrderPaymentStatus {
  PENDING_DEPOSIT
  DEPOSIT_COLLECTED
  PARTIAL
  PAID_IN_FULL
  OVERDUE
  WRITTEN_OFF
}

model ServiceOrder {
  id            String                    @id @default(cuid())
  tenantId      String
  number        String                    @unique // URL-safe opaque, ≥80 bits
  mode          ServiceMode
  status        ServiceOrderStatus        @default(DRAFT)
  paymentStatus ServiceOrderPaymentStatus @default(PENDING_DEPOSIT)
  branchId      String

  // Customer is captured as a snapshot until the CRM lands in Phase 4.
  // Fields are denormalised JSON; we'll migrate to a Customer relation later.
  customerSnapshot  Json // { name, contactNumbers, idNumber?, address? }
  consigneeSnapshot Json // { name, contactNumbers, address: {...PH address fields} }

  pickupAddress    Json? // for deliver_box; structured HK address
  scheduledPickupAt DateTime?
  packedAt         DateTime?
  storedAt         DateTime?
  paidInFullAt     DateTime?
  cancelledAt      DateTime?
  abandonmentDueAt DateTime? // computed when status moves to relevant states

  // FK placeholders — populated when those capabilities land.
  agentId       String? // for agent_intake (agents capability — later)
  manifestId    String? // for macau_intake (manifests capability — later)
  declarationId String? // declarations capability — later

  notes      String?
  createdBy  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  branch       Branch              @relation(fields: [branchId], references: [id])
  events       ServiceOrderEvent[]
  boxes        Box[]
  paymentLines PaymentLine[]

  @@index([tenantId, status])
  @@index([tenantId, branchId, status])
  @@index([tenantId, mode])
  @@index([tenantId, createdAt])
  @@index([status, abandonmentDueAt])
  @@map("service_orders")
}

// Status-transition history. Internal-only; the public tracking timeline
// is the separate (later) capability.
model ServiceOrderEvent {
  id             String             @id @default(cuid())
  tenantId       String
  serviceOrderId String
  fromStatus     ServiceOrderStatus?
  toStatus       ServiceOrderStatus
  reason         String?
  recordedBy     String
  requestId      String?
  createdAt      DateTime           @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId, serviceOrderId, createdAt])
  @@map("service_order_events")
}

// ─── Boxes ─────────────────────────────────────────────────────
// Physical box instance attached to a Service Order. Per
// openspec/changes/align-with-exspeed-workflows.
// This slice models add/remove boxes while the order is in DRAFT.
// Pre-printed agent numbers, putaway to bins, and the receive→pack→
// palletize→containerize→ship→delivered status walk land in follow-up
// slices alongside the agents / receiving / pallets-containers
// capabilities.

enum BoxStatus {
  CREATED
  RECEIVED
  PACKED
  PALLETIZED
  CONTAINERIZED
  IN_TRANSIT
  DELIVERED
  FAILED_DELIVERY
  RETURNED
}

model Box {
  id             String     @id @default(cuid())
  tenantId       String
  number         String     @unique // "B-" + 16-char URL-safe (system) or pre-printed agent-allocated
  serviceOrderId String
  boxTypeCode    BoxTypeCode
  status         BoxStatus  @default(CREATED)
  // When the number came from an agent's pre-printed batch, both are set.
  // Allows commission accounting + batch-level reporting later.
  agentId           String?
  boxNumberBatchId  String?
  // Oversize tracking. Per the price list: $60 HKD/inch (HK origin) or $30 MOP/inch (Macau).
  // The longest dimension over 41 inches (KING's long side) is the chargeable overage.
  oversizeInches Int? // null = not oversized
  // Optional weight + cubic measurements for billing + carrier handoff. Captured at receipt.
  weightKg       Decimal? @db.Decimal(7, 2)
  notes          String?
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  serviceOrder   ServiceOrder    @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  agent          Agent?          @relation(fields: [agentId], references: [id])
  boxNumberBatch BoxNumberBatch? @relation(fields: [boxNumberBatchId], references: [id])
  paymentLines   PaymentLine[]

  @@index([tenantId, serviceOrderId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, agentId])
  @@index([boxNumberBatchId])
  @@map("boxes")
}

// ─── Payments & deposits ───────────────────────────────────────
// The money side of every Service Order. Per
// openspec/changes/align-with-exspeed-workflows/specs/payments-deposits.
// Append-only ledger: every charge and every receipt is a positive line;
// corrections are new lines linking the original. Balance is computed,
// never stored. Multi-currency (HKD/MOP/PHP) — no cross-currency conversion.

enum PaymentLineKind {
  BOX_DEPOSIT
  BOX_BALANCE
  INSTANT_PACK_DISCOUNT
  TAKE_OUT_BOX_DISCOUNT
  LOYALTY_REDEMPTION
  OVERSIZE_SURCHARGE
  STORAGE_DEPOSIT
  PAID_STORAGE_CHARGE
  STORAGE_PICKUP_FEE
  AGENT_COMMISSION
  RECEIVED
  BOUNCED
  CORRECTION
}

model PaymentLine {
  id             String          @id @default(cuid())
  tenantId       String
  serviceOrderId String
  boxId          String?
  agentId        String? // set on AGENT_COMMISSION lines so payouts are queryable per agent
  kind           PaymentLineKind
  // Signed minor units. Charges are positive; discounts/receipts/commissions
  // are negative; corrections carry the offsetting sign. See the capability
  // spec's kind table.
  amount         BigInt
  currencyCode   String
  reason         String
  relatedLineId  String? // for CORRECTION / BOUNCED → the line being reversed
  accruedAt      DateTime        @default(now())
  recordedBy     String
  requestId      String?
  createdAt      DateTime        @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  box          Box?         @relation(fields: [boxId], references: [id])
  agent        Agent?       @relation(fields: [agentId], references: [id])
  relatedLine  PaymentLine? @relation("PaymentLineCorrection", fields: [relatedLineId], references: [id])
  corrections  PaymentLine[] @relation("PaymentLineCorrection")

  @@index([tenantId, serviceOrderId])
  @@index([tenantId, kind])
  @@index([tenantId, agentId])
  @@index([tenantId, createdAt])
  @@map("payment_lines")
}

// ─── Agents & box-number batches ───────────────────────────────
// Partner intake. Per
// openspec/changes/align-with-exspeed-workflows/specs/agents/spec.md.
// This slice covers Agent CRUD + batch issuance + atomic next-number
// allocation. Agent-intake wiring on the box endpoints and remittance
// accounting (commission ledger) land in follow-up slices.

enum BoxNumberBatchStatus {
  ACTIVE
  EXHAUSTED
  VOIDED
}

model Agent {
  id                    String   @id @default(cuid())
  tenantId              String
  code                  String // tenant-unique short identifier (e.g. "AG-CW-001")
  name                  String
  branchId              String? // optional anchor branch for reconciliation
  // Commission policy: either a percentage of received amount OR a flat per-box rate.
  // Both null means commission is settled out-of-band.
  commissionPercent     Decimal? @db.Decimal(5, 2) // 0.00 - 100.00
  commissionPerBoxMinor BigInt?
  commissionCurrency    String? // 3-letter ISO
  contactInfo           Json? // { email, phone[], whatsapp?, address? }
  isActive              Boolean  @default(true)
  createdBy             String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  branch           Branch?          @relation(fields: [branchId], references: [id])
  boxNumberBatches BoxNumberBatch[]
  boxes            Box[]
  paymentLines     PaymentLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("agents")
}

model BoxNumberBatch {
  id          String               @id @default(cuid())
  tenantId    String
  agentId     String
  // The number is composed: `prefix` + zero-padded sequence (6 digits).
  // E.g. prefix "EX-AG-001-" + seq 42 → "EX-AG-001-000042".
  prefix      String
  startSeq    Int
  endSeq      Int
  nextSeq     Int // bumped atomically on each allocation
  status      BoxNumberBatchStatus @default(ACTIVE)
  notes       String?
  issuedBy    String
  issuedAt    DateTime             @default(now())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  boxes  Box[]

  @@index([tenantId, agentId])
  @@index([tenantId, status])
  @@map("box_number_batches")
}
