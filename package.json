{
  "name": "logisti-core",
  "version": "0.1.0",
  "private": true,
  "description": "LogistiCore — Warehouse & Cargo Management Platform",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter=./apps/* --filter=./packages/* build",
    "lint": "pnpm -r --parallel lint",
    "lint:fix": "pnpm -r --parallel lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "test:e2e": "pnpm --filter @logisti-core/api test:e2e",
    "dev": "pnpm -r --parallel dev",
    "migrate": "pnpm --filter @logisti-core/api db:migrate",
    "seed": "pnpm --filter @logisti-core/api db:seed",
    "clean": "pnpm -r --parallel clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
